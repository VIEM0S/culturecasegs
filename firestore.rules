rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null;
    }
    match /data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /blog_posts/{docId} {
      allow read, write: if isAdmin();
      allow list, get: if true;
    }
    match /reviews/{docId} {
      allow read, write: if isAdmin();
      allow read: if resource.data.status == "published";
      allow create: if
        request.resource.data.status == "pending"
        && request.resource.data.txt is string
        && request.resource.data.txt.size() >= 15
        && request.resource.data.txt.size() <= 1000
        && request.resource.data.nom is string
        && request.resource.data.nom.size() >= 1
        && request.resource.data.nom.size() <= 100
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;
      allow update, delete: if false;
    }
    match /error_logs/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500;
      allow update, delete: if false;
    }
    match /android_waitlist/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.tel is string
        && request.resource.data.tel.size() >= 8
        && request.resource.data.tel.size() <= 20;
      allow update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

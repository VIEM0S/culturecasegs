rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    // Utilisateur authentifié (email ou anonyme)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Utilisateur email = admin (pas anonyme)
    function isAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "password";
    }

    // Viewer = auth anonyme
    function isViewer() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    // ── Validation du nom de document ─────────────────────────────────────
    // Seuls "main" et "products_0".."products_N" sont autorisés.
    // Cela empêche un attaquant authentifié d'écrire des documents arbitraires.
    function isValidDocId(docId) {
      return docId == "main"
        || docId.matches("products_[0-9]+");
    }

    // ── Collection "data" ──────────────────────────────────────────────────
    match /data/{docId} {

      // Lecture : admin ET viewer peuvent lire, uniquement les docs légitimes
      allow read: if isAuthenticated() && isValidDocId(docId);

      // Écriture (create, update, delete) : admin uniquement, docs légitimes
      allow write: if isAdmin() && isValidDocId(docId);
    }

    // ── Tout le reste est refusé ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
